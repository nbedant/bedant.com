---
import BaseLayout from "./BaseLayout.astro";

const { title, description, pubDate, collection } = Astro.props;
const sectionLabel = collection === "notes" ? "Notes" : "Essays";
const backHref = collection === "notes" ? "/notes/" : "/essays/";
const formattedDate = new Intl.DateTimeFormat("en", {
  month: "long",
  day: "numeric",
  year: "numeric",
  timeZone: "UTC",
}).format(pubDate);
---

<BaseLayout title={title} description={description}>
  <article class="writing-page">
    <a class="return-link" href={backHref}>{sectionLabel}</a>
    <header class="writing-header">
      <p class="kicker">{formattedDate}</p>
      <h1>{title}</h1>
      <p>{description}</p>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
