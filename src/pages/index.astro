---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const essays = (await getCollection("essays", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);
const notes = (await getCollection("notes", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);
---

<BaseLayout>
  <section class="hero">
    <div class="hero-copy">
      <p class="kicker">Between Body and Meaning</p>
      <h1>Writing toward the difficult places where bodies, minds, and meaning meet.</h1>
      <p>
        Bedant is a personal archive for essays and notes on medicine, grief,
        care, psychology, books, biology, research, philosophy, and the
        unexpected connections that make one subject illuminate another.
      </p>
    </div>
    <div class="room-plate" aria-hidden="true">
      <div class="navy-rule"></div>
      <div class="lamp"></div>
      <div class="shelf shelf-one"></div>
      <div class="shelf shelf-two"></div>
      <div class="chair"></div>
    </div>
  </section>

  <section class="intro-grid">
    <div>
      <h2>A quiet room for thinking in public.</h2>
      <p>
        Between Body and Meaning is where I keep longer essays and shorter
        notes while I learn how to think with more patience. Some pieces begin
        near hospice or caregiving. Others may begin with a paper, a novel, a
        phrase from class, or a strange analogy that refuses to leave.
      </p>
    </div>
    <aside class="note-panel" aria-label="Currently thinking about">
      <p class="panel-label">Currently thinking about</p>
      <p>
        Stress biology, grief before death, attention as a form of care, and
        why certain books make clinical questions feel more human.
      </p>
    </aside>
  </section>

  <section class="archive-preview" aria-labelledby="recent-essays">
    <div class="section-heading">
      <div>
        <p class="kicker">Archive</p>
        <h2 id="recent-essays">Recent essays</h2>
      </div>
      <a href="/essays/">All essays</a>
    </div>
    <div class="card-grid">
      {
        essays.map((essay) => (
          <a class="writing-card" href={`/essays/${essay.slug}/`}>
            <p class="card-meta">
              {essay.data.pubDate.toLocaleDateString("en", {
                month: "short",
                day: "numeric",
                year: "numeric",
                timeZone: "UTC",
              })}
            </p>
            <h3>{essay.data.title}</h3>
            <p>{essay.data.description}</p>
            {
              essay.data.tags.length > 0 && (
                <span class="mini-tags">{essay.data.tags.join(" / ")}</span>
              )
            }
          </a>
        ))
      }
    </div>
  </section>

  <section class="archive-preview" aria-labelledby="recent-notes">
    <div class="section-heading">
      <div>
        <p class="kicker">Notebook</p>
        <h2 id="recent-notes">Recent notes</h2>
      </div>
      <a href="/notes/">All notes</a>
    </div>
    <div class="card-grid">
      {
        notes.map((note) => (
          <a class="writing-card" href={`/notes/${note.slug}/`}>
            <p class="card-meta">
              {note.data.pubDate.toLocaleDateString("en", {
                month: "short",
                day: "numeric",
                year: "numeric",
                timeZone: "UTC",
              })}
            </p>
            <h3>{note.data.title}</h3>
            <p>{note.data.description}</p>
            {
              note.data.tags.length > 0 && (
                <span class="mini-tags">{note.data.tags.join(" / ")}</span>
              )
            }
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
