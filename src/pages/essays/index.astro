---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const essays = (await getCollection("essays", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout
  title="Essays"
  description="Longer essays from Between Body and Meaning."
>
  <section class="page-header">
    <p class="kicker">Essays</p>
    <h1>Longer reflections on care, suffering, and medicine.</h1>
    <p>
      Essays are the slowest pieces here: inquiries into grief, caregiving,
      clinical life, psychology, and what it means to accompany another person.
    </p>
  </section>

  <section class="archive-list" aria-label="Essays archive">
    {
      essays.map((essay) => (
        <a class="archive-item" href={`/essays/${essay.slug}/`}>
          <time datetime={essay.data.pubDate.toISOString()}>
            {essay.data.pubDate.toLocaleDateString("en", {
              month: "long",
              day: "numeric",
              year: "numeric",
              timeZone: "UTC",
            })}
          </time>
          <div>
            <h2>{essay.data.title}</h2>
            <p>{essay.data.description}</p>
          </div>
        </a>
      ))
    }
  </section>
</BaseLayout>
