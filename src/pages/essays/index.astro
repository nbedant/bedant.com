---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const getEntryDate = (entry) => entry.data.date ?? entry.data.pubDate;
const essays = (await getCollection("essays", ({ data }) => !data.draft)).sort(
  (a, b) => getEntryDate(b).valueOf() - getEntryDate(a).valueOf(),
);
---

<BaseLayout
  title="Essays"
  description="Longer essays from Between Body and Meaning."
>
  <section class="page-header">
    <p class="kicker">Essays</p>
    <h1>Longer pieces, written slowly.</h1>
    <p>
      Essays are the more deliberate pieces here: reflective arguments,
      personal inquiries, and close observations about care, grief, psychology,
      medicine, books, research, and the human questions that gather around
      them.
    </p>
  </section>

  <section class="archive-list" aria-label="Essays archive">
    {
      essays.map((essay) => (
        <a class="archive-item" href={`/essays/${essay.slug}/`}>
          <time datetime={getEntryDate(essay).toISOString()}>
            {getEntryDate(essay).toLocaleDateString("en", {
              month: "long",
              day: "numeric",
              year: "numeric",
              timeZone: "UTC",
            })}
          </time>
          <div>
            <h2>{essay.data.title}</h2>
            <p>{essay.data.description}</p>
            {
              essay.data.tags.length > 0 && (
                <span class="mini-tags">{essay.data.tags.join(" / ")}</span>
              )
            }
          </div>
        </a>
      ))
    }
  </section>
</BaseLayout>
